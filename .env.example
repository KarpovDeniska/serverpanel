# ServerPanel Configuration
# Copy to .env and fill in real values

# App
DEBUG=true
SECRET_KEY=change-me-generate-with-openssl-rand-hex-32

# Database (SQLite by default, switch to PostgreSQL with asyncpg)
DATABASE_URL=sqlite+aiosqlite:///./data/serverpanel.db
# DATABASE_URL=postgresql+asyncpg://user:password@localhost/serverpanel

# Encryption key for stored provider credentials
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=

# Session lifetime in hours
SESSION_LIFETIME_HOURS=24

# OAuth (optional, for future use)
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=
